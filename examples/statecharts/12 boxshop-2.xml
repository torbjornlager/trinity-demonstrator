<!--

    Another conversational agent written in a form-based style.

    Keep the Logger open and SXML trace selected.

-->

<statechart
       datamodel="web-prolog"
       initial="form">
    <state id="form" initial="selectFormItem">
        <datamodel>
            :- dynamic 
                welcome/0,
                color/1,
                size/1.
        </datamodel>
        <state id="selectFormItem">
            <go to="Welcome" if="\+ welcome"/>
            <go to="Color"   if="\+ color(_)"/>
            <go to="Size"    if="\+ size(_)"/>
            <go to="Respond"/>
        </state>
        <state id="Welcome">
            <onentry>
                writeln('Welcome to the box shop!'),
                assert(welcome)
            </onentry>
            <go to="selectFormItem"/>
        </state>
        <state id="Color">
            <onentry>
                writeln('What color do you want?'),
                self(Self),
                send(Self, timeout, [delay(15), id(foo)])
            </onentry>
            <go to="selectFormItem" on="says(color(Color))">
                assert(color(Color))
            </go>
            <onexit>
                cancel(foo)
            </onexit>
        </state>
        <state id="Size">
            <onentry>
                writeln('What size do you want?'),
                self(Self),
                send(Self, timeout, [delay(15), id(bar)])
            </onentry>
            <go to="selectFormItem" on="says(size(Size))">
                assert(size(Size))
            </go>
            <onexit>
                cancel(bar)
            </onexit>
        </state>
        <go to="selectFormItem" on="says(_)">
            writeln('I did not understand.')
        </go>
        <go to="selectFormItem" on="timeout">
            writeln('I did not hear you.')
        </go>
    </state>
    <final id="Respond">
        <onentry>
            size(Size), color(Color),
            format('You want a ~p ~p box!\n', [Size, Color])
        </onentry>
    </final>
</statechart>


