digraph dependency_graph {
  graph [rankdir=TB, labelloc=t, labeljust=l, fontsize=20, fontname="Helvetica", overlap=false, splines=true, nodesep=0.28, ranksep=0.55, pad=0.2];
  node [shape=box, style="rounded", color="#666666", fontname="Helvetica", fontsize=11, margin="0.08,0.05"];
  edge [color="#555555", arrowsize=0.7, penwidth=1.0];
  label="Statechart Modules";
  n0 [label="prolog/web_prolog/actor_io_support.pl"];
  n1 [label="prolog/web_prolog/actors.pl"];
  n2 [label="prolog/web_prolog/isolation.pl"];
  n3 [label="prolog/web_prolog/source_utils.pl"];
  n4 [label="prolog/web_prolog/statechart_actor.pl"];
  n5 [label="prolog/web_prolog/statechart_exec.pl"];
  n6 [label="prolog/web_prolog/statechart_model.pl"];
  n7 [label="prolog/web_prolog/statechart_runtime.pl"];
  n8 [label="prolog/web_prolog/toplevel_actors.pl"];
  n4 -> n0;
  n4 -> n1;
  n4 -> n2;
  n4 -> n5;
  n4 -> n6;
  n4 -> n7;
  n4 -> n8;
  n5 -> n1;
  n5 -> n6;
  n5 -> n7;
  n6 -> n3;
  n7 -> n1;
  n7 -> n8;
}
