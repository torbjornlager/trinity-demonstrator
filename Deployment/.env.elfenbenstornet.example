# Environment for compose.elfenbenstornet.yaml.
#
#   cp Deployment/.env.elfenbenstornet.example Deployment/.env.elfenbenstornet
#   $EDITOR Deployment/.env.elfenbenstornet
#   docker compose -f Deployment/compose.elfenbenstornet.yaml \
#       --env-file Deployment/.env.elfenbenstornet up -d --build
#
# Keep the real .env.elfenbenstornet out of git (it holds OAuth secrets).

# Let's Encrypt registration email (cert-expiry notices).
ACME_EMAIL=you@example.com

# ── n5 SSO (GitHub OAuth app) ───────────────────────────────────────
# Reuse the same GitHub OAuth App you already use for n5 — its callback
# URL is unchanged:  https://n5.elfenbenstornet.se/oauth2/callback
# (If you don't have one: GitHub → Settings → Developer settings →
#  OAuth Apps → New, with that callback URL.)
OAUTH2_PROXY_PROVIDER=github
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
# A 32-byte secret:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=

# Registration allowlist — set ONE of these (otherwise anyone with a
# GitHub account who passes EMAIL_DOMAINS can register):
# OAUTH2_PROXY_GITHUB_USERS=your-github-login,another-login
# OAUTH2_PROXY_GITHUB_ORG=Web-Prolog
OAUTH2_PROXY_EMAIL_DOMAINS=*

# ── n5 node knobs (optional; defaults shown) ────────────────────────
# WP_N5_PROFILE=actor
# WP_N5_SANDBOX=blacklist
# WP_N5_DEFAULT_CAPS=execute
# WP_N5_OWNER=
