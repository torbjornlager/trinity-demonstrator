# ── n5 SSO (oauth2_n5) ──────────────────────────────────────────────
# OAuth/OIDC config for the n5 web-prolog node's oauth2-proxy sidecar.
# COPY THESE LINES INTO Deployment/.env (which is git-ignored) and fill
# them in — do NOT commit real secrets. They are read by compose.yaml's
# oauth2_n5 service.
#
# Register an OAuth app at your provider with the callback URL:
#     https://n5.elfenbenstornet.se/oauth2/callback

# Provider: github | google | oidc | gitlab | ...  (oauth2-proxy names)
OAUTH2_PROXY_PROVIDER=github

# OAuth app credentials from the provider.
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Cookie signing/encryption key — 32 random bytes, base64:
#     openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=

# ── Who may sign in (this allowlist *is* your registration policy) ──
# Set the one(s) that match your provider; leave the rest blank.
# GitHub: restrict to an org (and optionally team) or to named users.
OAUTH2_PROXY_GITHUB_ORG=
OAUTH2_PROXY_GITHUB_USERS=
# OIDC/Google: restrict by verified email domain. '*' = anyone with an
# account at the provider — usually NOT what you want for a public node.
# (Plural env var: --email-domain is repeatable.)
OAUTH2_PROXY_EMAIL_DOMAINS=*
# Generic OIDC only: the issuer discovery URL.
OAUTH2_PROXY_OIDC_ISSUER_URL=

# ── n5 node tuning (optional; all have safe defaults in compose.yaml) ──
# WP_N5_PROFILE=actor
# WP_N5_SANDBOX=whitelist          # or blacklist for a richer authed playground
# WP_N5_DEFAULT_CAPS=execute       # capabilities granted to logged-in users
# WP_N5_OWNER=owner
# WP_N5_MAX_ACTORS=10000
# WP_N5_MAX_CALL_INFERENCES=1000000000
# WP_N5_MAX_ACTOR_STACK_BYTES=268435456
