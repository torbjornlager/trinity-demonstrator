# n5: the layered web-prolog production node, gated by SSO (oauth2_n5).
# Every request must carry a valid session; the verified identity is
# handed to the node as X-Web-Prolog-User, which the node trusts only
# from this private proxy peer (request_forwarded_identity_trusted/1).
# Client-supplied trust headers are stripped first, so the only identity
# the node ever sees is the one oauth2-proxy just verified.
n5.elfenbenstornet.se {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# oauth2-proxy's own endpoints: sign-in, OAuth callback, sign-out.
	handle /oauth2/* {
		reverse_proxy oauth2_n5:4180 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Uri {uri}
		}
	}

	# Public, read-only demo assets. The node serves /examples and
	# /statecharts as unauthenticated static routes, and resolves
	# node-relative load_uri against its own public URL -- so e.g.
	# statechart_spawn(_, [load_uri('/examples/statecharts/...')]) (as in
	# the tutorial) makes the node fetch its own /examples URL
	# server-side, with no oauth2 cookie. Gating these behind forward_auth
	# bounces that self-fetch to the sign-in page, so the statechart
	# parser sees HTML ("No <statechart> root element found"). Serve them
	# without auth, stripping every client trust header so no anonymous
	# caller can claim a principal.
	@public_assets path /examples/* /statecharts/*
	handle @public_assets {
		reverse_proxy wp_n5:3060 {
			header_up -X-Web-Prolog-User
			header_up -X-Web-Prolog-Principal
			header_up -X-Authenticated-User
			header_up -X-Web-Prolog-Capabilities
			header_up -X-Web-Prolog-Caps
			header_up -X-Web-Prolog-Internal-Proxy
			header_up X-Forwarded-Proto https
		}
	}

	# Everything else requires a valid session.
	handle {
		forward_auth oauth2_n5:4180 {
			uri /oauth2/auth
			copy_headers X-Auth-Request-User X-Auth-Request-Email

			# Not signed in -> bounce the browser to the sign-in page.
			@unauth status 401
			handle_response @unauth {
				redir https://{host}/oauth2/sign_in?rd={scheme}://{host}{uri}
			}
		}

		reverse_proxy wp_n5:3060 {
			# Strip client-supplied trust headers we do NOT set ourselves.
			# NB: X-Web-Prolog-User is deliberately NOT deleted here — the
			# header_up Set below replaces any client value, and Caddy
			# applies deletes AFTER sets, so deleting it would wipe the
			# verified identity (the bug that 403'd /admin). Do not switch
			# this back to `import common_proxy_headers` (which deletes it).
			header_up -X-Web-Prolog-Principal
			header_up -X-Authenticated-User
			header_up -X-Web-Prolog-Capabilities
			header_up -X-Web-Prolog-Caps
			header_up -X-Web-Prolog-Internal-Proxy
			header_up X-Forwarded-Proto https
			# Set the node principal from the verified identity (replaces
			# any client copy). Email = stable principal id; swap in
			# X-Auth-Request-User for the provider username instead.
			header_up X-Web-Prolog-User {http.request.header.X-Auth-Request-Email}

			# ACTOR mode is long-lived WebSocket; don't time it out.
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}
}

