n3.elfenbenstornet.se {
	encode zstd gzip
	import cors_headers

	@options method OPTIONS
	handle @options {
		respond 204
	}

	@trusted_internal_ws {
		path /ws
		remote_ip private_ranges
	}
	@allowed {
		path / /call /manual /node_info /img* /portal /workbench /demonstrator /calculator /tutorial /editor_frame /examples_index /interaction_log /examples* /statecharts* /Tau-Prolog* /tau-examples* /swi-wasm-examples* /ws /toplevel_spawn /toplevel_call /toplevel_next /toplevel_poll /toplevel_stop /toplevel_abort /toplevel_trace /toplevel_respond
	}
	handle @trusted_internal_ws {
		reverse_proxy wp_n3:3053 {
			import common_proxy_headers
			import trusted_internal_transport_headers
		}
	}
	handle @allowed {
		reverse_proxy wp_n3:3053 {
			import common_proxy_headers
		}
	}

	respond "Not found" 404
}

