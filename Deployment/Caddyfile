{
	servers :443 {
		protocols h1 h2
	}
}

(cors_headers) {
	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, OPTIONS"
	header Access-Control-Allow-Headers "Content-Type"
}

(common_proxy_headers) {
	header_up -X-Web-Prolog-User
	header_up -X-Web-Prolog-Principal
	header_up -X-Web-Prolog-Capabilities
	header_up -X-Web-Prolog-Caps
	header_up -X-Web-Prolog-Internal-Proxy
	header_up -X-Authenticated-User
	header_up X-Forwarded-Proto https
	header_up X-Forwarded-Host {host}
}

(trusted_internal_transport_headers) {
	header_up X-Web-Prolog-User {header.X-Web-Prolog-User}
	header_up X-Web-Prolog-Capabilities {header.X-Web-Prolog-Capabilities}
	header_up X-Web-Prolog-Internal-Proxy true
}

n0.elfenbenstornet.se {
	encode zstd gzip
	import cors_headers
	@options method OPTIONS
	handle @options {
		respond 204
	}
	@allowed path / /call /discovery-hub /admin/tabler.min.css /manual /node_info /version /healthz /readyz /img* /vendor* /portal /demonstrator /tutorial /editor_frame /examples_index /interaction_log /__viewer* /examples* /statecharts* /wasm* /swipl-bundle.js /swi_wasm_actor_worker.js
	handle @allowed {
		reverse_proxy n0:3060 {
			import common_proxy_headers
		}
	}
	respond "Not found" 404
}

