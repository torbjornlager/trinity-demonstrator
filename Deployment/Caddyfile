{
	servers :443 {
		protocols h1 h2
	}
}

(cors_headers) {
	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, OPTIONS"
	header Access-Control-Allow-Headers "Content-Type"
}

(common_proxy_headers) {
	header_up -X-Web-Prolog-User
	header_up -X-Web-Prolog-Principal
	header_up -X-Web-Prolog-Capabilities
	header_up -X-Web-Prolog-Caps
	header_up -X-Web-Prolog-Internal-Proxy
	header_up -X-Authenticated-User
	header_up X-Forwarded-Proto https
	header_up X-Forwarded-Host {host}
}

(trusted_internal_transport_headers) {
	header_up X-Web-Prolog-User {header.X-Web-Prolog-User}
	header_up X-Web-Prolog-Capabilities {header.X-Web-Prolog-Capabilities}
	header_up X-Web-Prolog-Internal-Proxy true
}

n1.elfenbenstornet.se {
	encode zstd gzip
	import cors_headers

	@options method OPTIONS
	handle @options {
		respond 204
	}

	@allowed path / /call /manual /node_info /img* /portal /workbench /demonstrator /tutorial /editor_frame /examples_index /interaction_log /examples* /statecharts* /Tau-Prolog* /tau-examples* /swi-wasm-examples*
	handle @allowed {
		reverse_proxy wp_n1:3051 {
			import common_proxy_headers
		}
	}

	respond "Not found" 404
}

